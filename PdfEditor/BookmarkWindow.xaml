<Window x:Class="PdfEditor.BookmarkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="书签设置" Height="150" Width="300"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <StackPanel Margin="10">
            <StackPanel Orientation="Horizontal">
                <Label Content="标题:" Width="60"/>
                <TextBox x:Name="TitleTextBox" Width="200"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Label Content="页码:" Width="60"/>
                <TextBox x:Name="PageTextBox" Width="200"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Right">
                <Button Content="确定" Click="Ok_Click" Width="70"/>
                <Button Content="取消" Click="Cancel_Click" Width="70"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>