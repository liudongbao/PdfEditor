<Window x:Class="PdfEditor.BatchBookmarkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量添加书签" Height="250" Width="350"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5">
            <Label Content="起始页码:" Width="80"/>
            <TextBox x:Name="StartPageTextBox" Width="200" Text="1"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <Label Content="结束页码:" Width="80"/>
            <TextBox x:Name="EndPageTextBox" Width="200" Text="1"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5">
            <Label Content="标题前缀:" Width="80"/>
            <TextBox x:Name="TitlePrefixTextBox" Width="200" Text="第"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Margin="0,5" Foreground="Gray">
            <Run Text="示例: 标题前缀" />
            <Run Text=" &quot;第&quot; " FontWeight="Bold"/>
            <Run Text="将生成: &quot;第 1&quot;, &quot;第 2&quot;, &quot;第 3&quot;..." />
        </TextBlock>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10" HorizontalAlignment="Right">
            <Button Content="确定" Click="Ok_Click" Width="70"/>
            <Button Content="取消" Click="Cancel_Click" Width="70" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>