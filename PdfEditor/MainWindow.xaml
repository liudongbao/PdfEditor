<Window x:Class="PdfEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="PDF 编辑工具" Height="850" Width="1250"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="文件">
                <MenuItem Header="打开 PDF" Click="OpenPdf_Click"/>
                <Separator/>
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="关于" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <TabControl x:Name="MainTabControl" Grid.Row="1" SelectionChanged="MainTabControl_SelectionChanged">
            <TabItem Header="PDF 合并">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Content="待合并的 PDF 文件:" Margin="4"/>
                        <ListBox x:Name="MergeFileList" Margin="4" SelectionMode="Extended" Height="400"/>
                        <StackPanel Orientation="Horizontal" Margin="4">
                            <Button Content="添加文件" Click="AddMergeFiles_Click"/>
                            <Button Content="移除选中" Click="RemoveMergeFiles_Click"/>
                            <Button Content="上移" Click="MoveMergeUp_Click"/>
                            <Button Content="下移" Click="MoveMergeDown_Click"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <ProgressBar x:Name="MergeProgress" Height="20" Margin="4" Visibility="Hidden"/>
                        <Button Content="开始合并" Click="MergePdfs_Click" Width="180" Margin="4"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="页面编辑">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Content="页面列表:" Margin="4"/>
                        <ListBox x:Name="PageList" Margin="4" SelectionMode="Extended" Height="400" SelectionChanged="PageList_SelectionChanged"/>
                        <StackPanel Orientation="Horizontal" Margin="4">
                            <Button Content="删除选中" Click="DeletePages_Click"/>
                            <Button Content="上移" Click="MovePageUp_Click"/>
                            <Button Content="下移" Click="MovePageDown_Click"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <Label Content="预览区域:" Margin="4"/>
                        <wv2:WebView2 x:Name="PdfPreview" Margin="4" Height="400" />
                        <Label x:Name="PreviewStatus" Content="正在初始化..." Margin="4" FontSize="12" Foreground="Gray"/>
                        <Button Content="保存修改" Click="SaveEditedPdf_Click" Width="180" Margin="4"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="格式导出">
                <StackPanel Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="ExportPdfPath" Width="400" Margin="4"/>
                        <Button Content="浏览..." Click="SelectExportPdf_Click"/>
                    </StackPanel>
                    <GroupBox Header="导出格式" Margin="4">
                        <StackPanel>
                            <CheckBox x:Name="ExportWord" Content="导出为 Word (.docx)" Margin="4"/>
                            <CheckBox x:Name="ExportExcel" Content="导出为 Excel (.xlsx)" Margin="4"/>
                            <CheckBox x:Name="ExportPpt" Content="导出为 PowerPoint (.pptx)" Margin="4"/>
                        </StackPanel>
                    </GroupBox>
                    <ProgressBar x:Name="ExportProgress" Height="20" Margin="4" Visibility="Hidden"/>
                    <Button Content="开始导出" Click="ExportFiles_Click" Width="180" Margin="4"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="目录管理">
                <Grid Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：书签列表区域 -->
                    <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" Margin="4" Background="White">
                        <DockPanel>
                            <!-- 顶部工具栏 -->
                            <Border DockPanel.Dock="Top" Background="#F0F0F0" Padding="8,6" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="书签" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#333333"/>
                                    <Button Content="添加" Click="AddBookmark_Click" Margin="20,0,0,0" Padding="12,4" Background="White" BorderBrush="#CCCCCC"/>
                                    <Button Content="编辑" Click="EditBookmark_Click" Margin="4,0,0,0" Padding="12,4" Background="White" BorderBrush="#CCCCCC"/>
                                    <Button Content="删除" Click="DeleteBookmark_Click" Margin="4,0,0,0" Padding="12,4" Background="White" BorderBrush="#CCCCCC"/>
                                    <Button Content="▼" Click="ShowBookmarkMenu_Click" Margin="4,0,0,0" Padding="8,4" Background="White" BorderBrush="#CCCCCC" FontSize="10"/>
                                </StackPanel>
                            </Border>

                            <!-- 搜索框 -->
                            <Border DockPanel.Dock="Top" Padding="8" Background="#FAFAFA" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                                <TextBox x:Name="BookmarkSearchBox" Height="28" VerticalContentAlignment="Center" 
                                         Padding="8,0" FontSize="12" BorderBrush="#CCCCCC"
                                         TextChanged="BookmarkSearchBox_TextChanged"/>
                            </Border>

                            <!-- 书签树 -->
                            <TreeView x:Name="BookmarkTree" Margin="4"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      SelectedItemChanged="BookmarkTree_SelectedItemChanged"
                                      AllowDrop="True"
                                      MouseMove="BookmarkTree_MouseMove"
                                      Drop="BookmarkTree_Drop"
                                      DragOver="BookmarkTree_DragOver">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="True"/>
                                        <Setter Property="Padding" Value="4,2"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding Color}"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Title}" FontWeight="{Binding FontWeight}" FontSize="13"/>
                                            <TextBlock Text="  " Foreground="#999999"/>
                                            <TextBlock Text="第" Foreground="#999999" FontSize="12"/>
                                            <TextBlock Text="{Binding PageDisplay}" Foreground="#666666" FontSize="12"/>
                                            <TextBlock Text="页" Foreground="#999999" FontSize="12"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </DockPanel>
                    </Border>

                    <!-- 右侧：PDF 预览和导航区域 -->
                    <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,4,4,4" Background="White">
                        <DockPanel>
                            <!-- 顶部工具栏 -->
                            <Border DockPanel.Dock="Top" Background="#F0F0F0" Padding="8,6" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- 左侧：快速添加书签 -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="快速添加书签：" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBox x:Name="QuickBookmarkTitle" Width="180" Height="26" Margin="6,0"
                                                 VerticalContentAlignment="Center" ToolTip="输入书签标题"/>
                                        <Button Content="添加" Click="QuickAddBookmark_Click" Padding="16,4" Background="#4A90E2" Foreground="White" BorderThickness="0"/>
                                        <Button Content="批量添加" Click="BatchAddBookmarks_Click" Padding="12,4" Margin="6,0,0,0" Background="White" BorderBrush="#CCCCCC"/>
                                    </StackPanel>

                                    <!-- 右侧：页面导航 -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock x:Name="CurrentPageText" Text="第 1 / 1 页" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
                                        <Button Content="◀" Click="PrevPage_Click" Width="30" Height="26" Padding="0" FontSize="12"/>
                                        <Button Content="▶" Click="NextPage_Click" Width="30" Height="26" Margin="4,0,0,0" Padding="0" FontSize="12"/>
                                        <Button Content="跳转到" Click="JumpToBookmarkPage_Click" Margin="10,0,0,0" Padding="10,4" Background="White" BorderBrush="#CCCCCC"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- PDF 预览区域 -->
                            <wv2:WebView2 x:Name="BookmarkPreview" DockPanel.Dock="Top" Margin="8" Height="450"/>

                            <!-- 底部：书签样式设置 -->
                            <Border DockPanel.Dock="Bottom" Background="#FAFAFA" Padding="8" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="书签样式：" VerticalAlignment="Center" FontSize="12"/>
                                    <ComboBox x:Name="BookmarkColorCombo" Width="100" Margin="6,0" SelectedIndex="0">
                                        <ComboBoxItem Content="红色" Tag="#FF0000"/>
                                        <ComboBoxItem Content="蓝色" Tag="#0000FF"/>
                                        <ComboBoxItem Content="绿色" Tag="#00AA00"/>
                                        <ComboBoxItem Content="黄色" Tag="#FFCC00"/>
                                        <ComboBoxItem Content="紫色" Tag="#9900FF"/>
                                        <ComboBoxItem Content="灰色" Tag="#888888"/>
                                    </ComboBox>
                                    <CheckBox x:Name="BookmarkBoldCheck" Content="加粗" VerticalAlignment="Center" Margin="6,0"/>
                                    <Button Content="应用样式" Click="ApplyBookmarkStyle_Click" Padding="16,4" Background="#4A90E2" Foreground="White" BorderThickness="0"/>
                                </StackPanel>
                            </Border>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>