<Window x:Class="PdfEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDF 编辑工具" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="文件">
                <MenuItem Header="打开 PDF" Click="OpenPdf_Click"/>
                <Separator/>
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="关于" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <TabControl x:Name="MainTabControl" Grid.Row="1" SelectionChanged="MainTabControl_SelectionChanged">
            <TabItem Header="PDF 合并">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Content="待合并的 PDF 文件:" Margin="4"/>
                        <ListBox x:Name="MergeFileList" Margin="4" SelectionMode="Extended" Height="400"/>
                        <StackPanel Orientation="Horizontal" Margin="4">
                            <Button Content="添加文件" Click="AddMergeFiles_Click"/>
                            <Button Content="移除选中" Click="RemoveMergeFiles_Click"/>
                            <Button Content="上移" Click="MoveMergeUp_Click"/>
                            <Button Content="下移" Click="MoveMergeDown_Click"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <ProgressBar x:Name="MergeProgress" Height="20" Margin="4" Visibility="Hidden"/>
                        <Button Content="开始合并" Click="MergePdfs_Click" Width="180" Margin="4"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="页面编辑">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Content="页面列表:" Margin="4"/>
                        <ListBox x:Name="PageList" Margin="4" SelectionMode="Extended" Height="400"/>
                        <StackPanel Orientation="Horizontal" Margin="4">
                            <Button Content="删除选中" Click="DeletePages_Click"/>
                            <Button Content="上移" Click="MovePageUp_Click"/>
                            <Button Content="下移" Click="MovePageDown_Click"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <Label Content="预览区域:" Margin="4"/>
                        <Border BorderBrush="Gray" BorderThickness="1" Margin="4" Height="400" Background="LightGray"/>
                        <Button Content="保存修改" Click="SaveEditedPdf_Click" Width="180" Margin="4"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="格式导出">
                <StackPanel Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="ExportPdfPath" Width="400" Margin="4"/>
                        <Button Content="浏览..." Click="SelectExportPdf_Click"/>
                    </StackPanel>
                    <GroupBox Header="导出格式" Margin="4">
                        <StackPanel>
                            <CheckBox x:Name="ExportWord" Content="导出为 Word (.docx)" Margin="4"/>
                            <CheckBox x:Name="ExportExcel" Content="导出为 Excel (.xlsx)" Margin="4"/>
                        </StackPanel>
                    </GroupBox>
                    <ProgressBar x:Name="ExportProgress" Height="20" Margin="4" Visibility="Hidden"/>
                    <Button Content="开始导出" Click="ExportFiles_Click" Width="180" Margin="4"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="目录管理">
                <StackPanel Margin="4">
                    <TreeView x:Name="BookmarkTree" Margin="4" Height="400"/>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <Button Content="添加书签" Click="AddBookmark_Click"/>
                        <Button Content="编辑书签" Click="EditBookmark_Click"/>
                        <Button Content="删除书签" Click="DeleteBookmark_Click"/>
                    </StackPanel>
                    <Button Content="保存目录到 PDF" Click="SaveBookmarks_Click" Width="200" Margin="4"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>